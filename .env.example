# Frontegg Account Migration Configuration
# Copy this file to .env and fill in your actual values

# ===========================
# SOURCE ACCOUNT (Account 1)
# ===========================
# Base URL for the source Frontegg account
# Options: https://api.frontegg.com (EU), https://api.us.frontegg.com (US), 
#          https://api.ca.frontegg.com (CA), https://api.au.frontegg.com (AU)
BASE_URL_1=https://api.frontegg.com

# Source account credentials
CLIENT_ID_1=your-source-client-id-here
API_KEY_1=your-source-api-key-here

# ===========================
# DESTINATION ACCOUNT (Account 2)
# ===========================
# Base URL for the destination Frontegg account
BASE_URL_2=https://api.us.frontegg.com

# Destination account credentials
CLIENT_ID_2=your-destination-client-id-here
API_KEY_2=your-destination-api-key-here

# ===========================
# MIGRATION CONTROL FLAGS
# ===========================
# Set to True to enable migration of specific components

# Core entities
MIGRATE_TENANTS=False
MIGRATE_CATEGORIES=False
MIGRATE_PERMISSIONS=False
MIGRATE_ROLES=False
MIGRATE_USERS=False
MIGRATE_USER_ROLES=False

# Bulk operations
BULK_INVITE_USERS_TO_TENANTS=False
ASSIGN_ROLES_TO_USERS_ON_ALL_TENANTS=False

# Additional components
MIGRATE_GROUPS=False
MIGRATE_APPLICATIONS=False
MIGRATE_SECURITY_RULES=False

# Email configuration
MIGRATE_EMAIL_TEMPLATES=False
MIGRATE_EMAIL_SENDER=False

# Prehooks and origins
MIGRATE_PREHOOKS=False
MIGRATE_ALLOWED_ORIGINS=False

# JWT configuration (note: typo kept for backward compatibility)
MIGRATE_JWT_SETTINTS=False

# ===========================
# DELETION CONTROL FLAGS
# ===========================
# Used by delete_account_data.py to clean up destination account
# Set to True to enable deletion of specific components

DELETE_TENANTS=False
DELETE_USERS=False
DELETE_PERMISSIONS=False
DELETE_ROLES=False
DELETE_APPLICATIONS=False

# ===========================
# LOGGING CONFIGURATION
# ===========================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ===========================
# NOTES
# ===========================
# 1. Always test migrations in a non-production environment first
# 2. The order of migrations matters - basic entities should be migrated before dependent ones
# 3. Recommended order: Tenants → Categories → Permissions → Roles → Users → User Roles → Groups
# 4. JWT Settings flag has a typo (SETTINTS instead of SETTINGS) for backward compatibility
# 5. Make sure to backup your destination account data before running migrations
# 6. Some migrations are idempotent and can be run multiple times safely